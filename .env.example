# Grafana admin credentials
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=admin

# Retention (h = ore, d = giorni, w = settimane)
LOKI_RETENTION_PERIOD=744h
TEMPO_BLOCK_RETENTION=168h
MIMIR_BLOCKS_RETENTION=2160h

# Trace sampling
TRACE_SAMPLING_RATE=20
TRACE_LATENCY_THRESHOLD_MS=2000
TRACE_DECISION_WAIT=10s
