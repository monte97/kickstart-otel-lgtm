{
  "annotations": { "list": [] },
  "description": "Health dell'OTel Collector: spans/logs/metriche ricevuti, esportati e dropped",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(otelcol_receiver_accepted_spans_total[$__rate_interval])",
          "legendFormat": "Accepted — {{receiver}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(otelcol_receiver_refused_spans_total[$__rate_interval])",
          "legendFormat": "Refused — {{receiver}}"
        }
      ],
      "title": "Spans Ricevuti / Rifiutati",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(otelcol_exporter_sent_spans_total[$__rate_interval])",
          "legendFormat": "Sent — {{exporter}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(otelcol_exporter_send_failed_spans_total[$__rate_interval])",
          "legendFormat": "Failed — {{exporter}}"
        }
      ],
      "title": "Spans Esportati / Falliti",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "orientation": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "otelcol_exporter_queue_size",
          "legendFormat": "{{exporter}}"
        }
      ],
      "title": "Exporter Queue Size",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "mimir" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "calcs": ["mean"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(otelcol_processor_dropped_spans_total[$__rate_interval])",
          "legendFormat": "Dropped spans — {{processor}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "mimir" },
          "expr": "rate(otelcol_processor_dropped_log_records_total[$__rate_interval])",
          "legendFormat": "Dropped logs — {{processor}}"
        }
      ],
      "title": "Dropped Items (memory limiter)",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["observability", "otel", "collector-health"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "OTel Collector Health",
  "uid": "otel-collector-health",
  "version": 1
}
