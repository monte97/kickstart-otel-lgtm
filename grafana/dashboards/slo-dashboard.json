{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "uid": "slo-dashboard-mimir",
  "title": "SLO Dashboard",
  "description": "Service Level Objectives — error budget, burn rate e availability per servizio. Basato su span metrics di Tempo.",
  "tags": ["slo", "observability", "red-metrics"],
  "style": "dark",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 36,
  "refresh": "5m",
  "time": {"from": "now-30d", "to": "now"},
  "timepicker": {
    "refresh_intervals": ["5m","15m","30m","1h","2h","1d"],
    "time_options": ["1h","6h","12h","24h","7d","30d"]
  },
  "links": [],
  "annotations": {"list": []},
  "templating": {
    "list": [
      {
        "name": "service", "label": "Service", "type": "query",
        "datasource": {"type": "prometheus", "uid": "mimir"},
        "definition": "label_values(traces_spanmetrics_calls_total, service)",
        "query": {"query": "label_values(traces_spanmetrics_calls_total, service)", "refId": "StandardVariableQuery"},
        "refresh": 2, "sort": 1, "includeAll": false,
        "multi": false, "hide": 0, "current": {}
      },
      {
        "name": "slo_target", "label": "SLO Target (%)", "type": "custom",
        "hide": 0,
        "options": [
          {"selected": false, "text": "99.9", "value": "0.999"},
          {"selected": true, "text": "99.5", "value": "0.995"},
          {"selected": false, "text": "99.0", "value": "0.99"},
          {"selected": false, "text": "95.0", "value": "0.95"}
        ],
        "current": {"selected": true, "text": "99.5", "value": "0.995"},
        "query": "0.999,0.995,0.99,0.95"
      },
      {
        "name": "window", "label": "Rolling Window", "type": "custom",
        "hide": 0,
        "options": [
          {"selected": false, "text": "7d", "value": "7d"},
          {"selected": true, "text": "30d", "value": "30d"},
          {"selected": false, "text": "28d", "value": "28d"}
        ],
        "current": {"selected": true, "text": "30d", "value": "30d"},
        "query": "7d,30d,28d"
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "row", "title": "SLO Summary", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2, "type": "stat", "title": "Current Availability (rolling $window)",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 0.99},
            {"color": "green", "value": 0.999}
          ]},
          "min": 0.9, "max": 1
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "1 - (sum(rate(traces_spanmetrics_calls_total{service=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[$window])) / sum(rate(traces_spanmetrics_calls_total{service=\"$service\"}[$window])))", "legendFormat": "availability"}]
    },
    {
      "id": 3, "type": "stat", "title": "SLO Target",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "decimals": 1,
          "color": {"mode": "fixed", "fixedColor": "blue"},
          "noValue": "$slo_target"
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "value", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "$slo_target", "legendFormat": "target"}]
    },
    {
      "id": 4, "type": "stat", "title": "Error Budget Remaining (hours)",
      "description": "Remaining error budget based on the rolling window. Green = budget available, Red = budget exhausted.",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "h", "decimals": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "red", "value": null},
            {"color": "yellow", "value": 1},
            {"color": "green", "value": 6}
          ]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "((1 - $slo_target) - (sum(rate(traces_spanmetrics_calls_total{service=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[$window])) / sum(rate(traces_spanmetrics_calls_total{service=\"$service\"}[$window])))) * 720", "legendFormat": "budget remaining"}]
    },
    {
      "id": 5, "type": "gauge", "title": "Error Budget Consumed (%)",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"color": "green", "value": null},
            {"color": "yellow", "value": 0.5},
            {"color": "red", "value": 0.9}
          ]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "showThresholdLabels": false, "showThresholdMarkers": true},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "clamp_min(clamp_max((sum(rate(traces_spanmetrics_calls_total{service=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[$window])) / sum(rate(traces_spanmetrics_calls_total{service=\"$service\"}[$window]))) / (1 - $slo_target), 0), 1)", "legendFormat": "consumed"}]
    },
    {
      "id": 10, "type": "row", "title": "Availability Over Time", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6}
    },
    {
      "id": 11, "type": "timeseries", "title": "Availability vs SLO Target (rolling $window)",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 7},
      "fieldConfig": {
        "defaults": {"unit": "percentunit", "min": 0.9, "max": 1, "custom": {"lineWidth": 2, "fillOpacity": 10}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "SLO Target"}, "properties": [{"id": "custom.lineStyle", "value": {"dash": [10, 10], "fill": "dash"}}, {"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}, {"id": "custom.lineWidth", "value": 1}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "1 - (sum(rate(traces_spanmetrics_calls_total{service=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[$window])) / sum(rate(traces_spanmetrics_calls_total{service=\"$service\"}[$window])))", "legendFormat": "Availability"},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "$slo_target", "legendFormat": "SLO Target"}
      ]
    },
    {
      "id": 20, "type": "row", "title": "Burn Rate", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 15}
    },
    {
      "id": 21, "type": "timeseries", "title": "Error Burn Rate (1h / 6h / 24h)",
      "description": "Burn rate > 1 means consuming error budget faster than allowed. Burn rate > 14.4 triggers fast-burn alert.",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2, "fillOpacity": 5}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Threshold (1x)"}, "properties": [{"id": "custom.lineStyle", "value": {"dash": [10, 10], "fill": "dash"}}, {"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}, {"id": "custom.lineWidth", "value": 1}]},
          {"matcher": {"id": "byName", "options": "Fast burn (14.4x)"}, "properties": [{"id": "custom.lineStyle", "value": {"dash": [5, 5], "fill": "dash"}}, {"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}, {"id": "custom.lineWidth", "value": 1}]}
        ]
      },
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "(sum(rate(traces_spanmetrics_calls_total{service=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[1h])) / sum(rate(traces_spanmetrics_calls_total{service=\"$service\"}[1h]))) / (1 - $slo_target)", "legendFormat": "Burn Rate 1h"},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "(sum(rate(traces_spanmetrics_calls_total{service=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[6h])) / sum(rate(traces_spanmetrics_calls_total{service=\"$service\"}[6h]))) / (1 - $slo_target)", "legendFormat": "Burn Rate 6h"},
        {"refId": "C", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "(sum(rate(traces_spanmetrics_calls_total{service=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[24h])) / sum(rate(traces_spanmetrics_calls_total{service=\"$service\"}[24h]))) / (1 - $slo_target)", "legendFormat": "Burn Rate 24h"},
        {"refId": "D", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "1", "legendFormat": "Threshold (1x)"},
        {"refId": "E", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "14.4", "legendFormat": "Fast burn (14.4x)"}
      ]
    },
    {
      "id": 30, "type": "row", "title": "Request Detail", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 24}
    },
    {
      "id": 31, "type": "timeseries", "title": "Request Rate & Errors",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 25},
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"lineWidth": 2, "fillOpacity": 5}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"$service\"}[$__rate_interval]))", "legendFormat": "Total"},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval]))", "legendFormat": "Errors"}
      ]
    },
    {
      "id": 32, "type": "timeseries", "title": "Error Ratio",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 25},
      "fieldConfig": {"defaults": {"unit": "percentunit", "custom": {"lineWidth": 2, "fillOpacity": 5}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "list", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(traces_spanmetrics_calls_total{service=\"$service\",status_code=\"STATUS_CODE_ERROR\"}[$__rate_interval])) / sum(rate(traces_spanmetrics_calls_total{service=\"$service\"}[$__rate_interval]))", "legendFormat": "Error Ratio"},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "1 - $slo_target", "legendFormat": "Error Budget Limit"}
      ]
    }
  ]
}
