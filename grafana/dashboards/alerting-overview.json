{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "uid": "alerting-overview",
  "title": "Alerting Overview",
  "description": "Current firing and pending Grafana alert rules with severity breakdown.",
  "tags": ["alerting", "observability"],
  "style": "dark",
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 36,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "links": [
    {
      "title": "Alert Rules", "type": "link",
      "url": "/alerting/list",
      "targetBlank": false, "icon": "bell"
    }
  ],
  "annotations": {"list": []},
  "templating": {"list": []},
  "panels": [
    {
      "id": 1, "type": "row", "title": "Alert Status", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2, "type": "stat", "title": "Firing Alerts",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "mappings": [{"type": "value", "options": {"0": {"text": "OK", "color": "green"}}}]
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)", "legendFormat": "Firing"}]
    },
    {
      "id": 3, "type": "stat", "title": "Pending Alerts",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "count(ALERTS{alertstate=\"pending\"}) or vector(0)", "legendFormat": "Pending"}]
    },
    {
      "id": 4, "type": "stat", "title": "Critical",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "count(ALERTS{alertstate=\"firing\",severity=\"critical\"}) or vector(0)", "legendFormat": "Critical"}]
    },
    {
      "id": 5, "type": "stat", "title": "Warning",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "count(ALERTS{alertstate=\"firing\",severity=\"warning\"}) or vector(0)", "legendFormat": "Warning"}]
    },
    {
      "id": 6, "type": "stat", "title": "Info",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "blue", "value": 1}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "count(ALERTS{alertstate=\"firing\",severity=\"info\"}) or vector(0)", "legendFormat": "Info"}]
    },
    {
      "id": 7, "type": "stat", "title": "System Status",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "none", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]},
          "mappings": [{"type": "value", "options": {"0": {"text": "HEALTHY", "color": "green"}, "1": {"text": "DEGRADED", "color": "red"}}}]
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "auto", "textMode": "value", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "count(ALERTS{alertstate=\"firing\",severity=\"critical\"}) > 0 or vector(0)", "legendFormat": "Status"}]
    },
    {
      "id": 10, "type": "row", "title": "Firing Alerts Detail", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}
    },
    {
      "id": 11, "type": "table", "title": "Firing Alerts",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 6},
      "fieldConfig": {
        "defaults": {"custom": {"displayMode": "auto", "filterable": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "severity"}, "properties": [{"id": "custom.displayMode", "value": "color-background"}, {"id": "mappings", "value": [{"type": "value", "options": {"critical": {"color": "red", "index": 0}, "warning": {"color": "yellow", "index": 1}, "info": {"color": "blue", "index": 2}}}]}]},
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]},
          {"matcher": {"id": "byName", "options": "Value"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      },
      "options": {"footer": {"show": false}},
      "transformations": [{"id": "labelsToFields", "options": {"mode": "columns"}}, {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true, "alertstate": true}}}],
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "ALERTS{alertstate=\"firing\"}", "format": "table", "instant": true, "legendFormat": ""}]
    },
    {
      "id": 20, "type": "row", "title": "Pending Alerts", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16}
    },
    {
      "id": 21, "type": "table", "title": "Pending Alerts",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 17},
      "fieldConfig": {
        "defaults": {"custom": {"displayMode": "auto", "filterable": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Time"}, "properties": [{"id": "custom.hidden", "value": true}]},
          {"matcher": {"id": "byName", "options": "Value"}, "properties": [{"id": "custom.hidden", "value": true}]}
        ]
      },
      "options": {"footer": {"show": false}},
      "transformations": [{"id": "labelsToFields", "options": {"mode": "columns"}}, {"id": "organize", "options": {"excludeByName": {"Time": true, "Value": true, "__name__": true, "alertstate": true}}}],
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "ALERTS{alertstate=\"pending\"}", "format": "table", "instant": true, "legendFormat": ""}]
    },

    {
      "id": 30, "type": "row", "title": "Alert History", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 25}
    },
    {
      "id": 31,
      "type": "timeseries",
      "title": "Alert Firings Over Time",
      "description": "Number of alert state-change events per 5m bucket, by alert name. Requires Grafana Unified Alerting → Loki state history backend (GF_UNIFIED_ALERTING_STATE_HISTORY_BACKEND=loki).",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 26},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {"lineWidth": 2, "fillOpacity": 10, "gradientMode": "none", "drawStyle": "bars"},
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "tooltip": {"mode": "multi", "sort": "desc"},
        "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["sum"]}
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "sum by (alertname) (count_over_time({grafana_folder=\"Observability\"} | json | current_state = \"Alerting\" [5m]))",
          "legendFormat": "{{alertname}}",
          "queryType": "range"
        }
      ]
    },
    {
      "id": 32,
      "type": "logs",
      "title": "Recent Alert State Changes",
      "description": "All alert state transitions (Normal ↔ Alerting ↔ Pending) written by Grafana Unified Alerting to Loki.",
      "datasource": {"type": "loki", "uid": "loki"},
      "gridPos": {"h": 12, "w": 24, "x": 0, "y": 34},
      "options": {
        "dedupStrategy": "none",
        "showLabels": false,
        "showCommonLabels": false,
        "showTime": true,
        "wrapLogMessage": false,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "loki", "uid": "loki"},
          "expr": "{grafana_folder=\"Observability\"} | json | line_format \"[{{.current_state}}] {{.ruleTitle}} (was: {{.previous_state}})\"",
          "queryType": "range"
        }
      ]
    }
  ]
}
