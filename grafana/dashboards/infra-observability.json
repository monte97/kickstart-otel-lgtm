{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"}
  ],
  "uid": "infra-full-observability",
  "title": "Infrastructure Full Observability",
  "description": "Panoramica completa dell'infrastruttura: CPU, memoria, rete, Block I/O e OTel Collector health — via docker_stats receiver e prometheus/self.",
  "tags": ["infrastructure", "docker", "observability", "otel"],
  "style": "dark",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {"from": "now-1h", "to": "now"},
  "timepicker": {},
  "links": [],
  "annotations": {"list": []},
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "mimir"},
        "definition": "label_values(container_memory_usage_total_bytes, container_name)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".*",
        "label": "Container",
        "multi": true,
        "name": "container",
        "options": [],
        "query": {"query": "label_values(container_memory_usage_total_bytes, container_name)", "refId": "StandardVariableQuery"},
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "id": 1, "type": "row", "title": "Overview", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0}
    },
    {
      "id": 2, "type": "stat", "title": "Containers Running",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "short", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 1}, {"color": "green", "value": 3}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "count(container_memory_usage_total_bytes{container_name=~\"$container\"})", "legendFormat": "containers"}]
    },
    {
      "id": 3, "type": "stat", "title": "Total CPU Usage",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 0.8}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(container_cpu_usage_nanoseconds_total{container_name=~\"$container\"}[$__rate_interval])) / 1e9", "legendFormat": "cpu"}]
    },
    {
      "id": 4, "type": "stat", "title": "Total Memory Used",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 8, "y": 1},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1073741824}, {"color": "red", "value": 3221225472}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(container_memory_usage_total_bytes{container_name=~\"$container\"})", "legendFormat": "memory"}]
    },
    {
      "id": 5, "type": "stat", "title": "Network RX (total)",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 12, "y": 1},
      "fieldConfig": {
        "defaults": {"unit": "Bps", "color": {"mode": "fixed", "fixedColor": "blue"}},
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(container_network_io_usage_rx_bytes_total{container_name=~\"$container\"}[$__rate_interval]))", "legendFormat": "rx"}]
    },
    {
      "id": 6, "type": "stat", "title": "Network TX (total)",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 16, "y": 1},
      "fieldConfig": {
        "defaults": {"unit": "Bps", "color": {"mode": "fixed", "fixedColor": "purple"}},
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(container_network_io_usage_tx_bytes_total{container_name=~\"$container\"}[$__rate_interval]))", "legendFormat": "tx"}]
    },
    {
      "id": 7, "type": "stat", "title": "OTel Collector Spans/s",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 4, "x": 20, "y": 1},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "green"}},
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(otelcol_receiver_accepted_spans_total[$__rate_interval]))", "legendFormat": "spans/s"}]
    },

    {
      "id": 10, "type": "row", "title": "CPU", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 5}
    },
    {
      "id": 11, "type": "timeseries", "title": "CPU Usage per Container (cores)",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 6},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_cpu_usage_nanoseconds_total{container_name=~\"$container\"}[$__rate_interval]) / 1e9", "legendFormat": "{{container_name}}"}]
    },
    {
      "id": 12, "type": "bargauge", "title": "CPU Usage Now (cores)",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 6},
      "fieldConfig": {
        "defaults": {
          "unit": "short", "min": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1.0}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_cpu_usage_nanoseconds_total{container_name=~\"$container\"}[$__rate_interval]) / 1e9", "legendFormat": "{{container_name}}"}]
    },

    {
      "id": 20, "type": "row", "title": "Memory", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 14}
    },
    {
      "id": 21, "type": "timeseries", "title": "Memory Usage per Container",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 16, "x": 0, "y": 15},
      "fieldConfig": {"defaults": {"unit": "bytes", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "container_memory_usage_total_bytes{container_name=~\"$container\"}", "legendFormat": "{{container_name}}"}]
    },
    {
      "id": 22, "type": "bargauge", "title": "Memory Usage Now",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 8, "x": 16, "y": 15},
      "fieldConfig": {
        "defaults": {
          "unit": "bytes", "min": 0,
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 536870912}, {"color": "red", "value": 1073741824}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "orientation": "horizontal", "displayMode": "gradient", "showUnfilled": true},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "container_memory_usage_total_bytes{container_name=~\"$container\"}", "legendFormat": "{{container_name}}"}]
    },
    {
      "id": 23, "type": "timeseries", "title": "Memory Usage % of Limit",
      "description": "Solo per i container con memory limit configurato.",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 23},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "container_memory_usage_total_bytes{container_name=~\"$container\"} / container_memory_total_bytes{container_name=~\"$container\"}", "legendFormat": "{{container_name}}"}]
    },

    {
      "id": 30, "type": "row", "title": "Network", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31}
    },
    {
      "id": 31, "type": "timeseries", "title": "Network RX per Container",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "fieldConfig": {"defaults": {"unit": "Bps", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_network_io_usage_rx_bytes_total{container_name=~\"$container\"}[$__rate_interval])", "legendFormat": "{{container_name}}"}]
    },
    {
      "id": 32, "type": "timeseries", "title": "Network TX per Container",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "fieldConfig": {"defaults": {"unit": "Bps", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"]}},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_network_io_usage_tx_bytes_total{container_name=~\"$container\"}[$__rate_interval])", "legendFormat": "{{container_name}}"}]
    },
    {
      "id": 33, "type": "timeseries", "title": "Network Errors RX + TX",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 6, "w": 24, "x": 0, "y": 40},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "custom": {"lineWidth": 1, "fillOpacity": 5}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_network_io_usage_rx_errors_total{container_name=~\"$container\"}[$__rate_interval])", "legendFormat": "RX errors {{container_name}}"},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_network_io_usage_tx_errors_total{container_name=~\"$container\"}[$__rate_interval])", "legendFormat": "TX errors {{container_name}}"}
      ]
    },

    {
      "id": 40, "type": "row", "title": "Block I/O", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 46}
    },
    {
      "id": 41, "type": "timeseries", "title": "Block I/O Read",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 47},
      "fieldConfig": {"defaults": {"unit": "Bps", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 5}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_blockio_io_service_bytes_recursive_total{container_name=~\"$container\",operation=\"read\"}[$__rate_interval])", "legendFormat": "{{container_name}}"}]
    },
    {
      "id": 42, "type": "timeseries", "title": "Block I/O Write",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 47},
      "fieldConfig": {"defaults": {"unit": "Bps", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 5}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_blockio_io_service_bytes_recursive_total{container_name=~\"$container\",operation=\"write\"}[$__rate_interval])", "legendFormat": "{{container_name}}"}]
    },

    {
      "id": 50, "type": "row", "title": "Container Summary Table", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 55}
    },
    {
      "id": 51, "type": "table", "title": "Container Resource Snapshot",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 56},
      "fieldConfig": {
        "defaults": {"custom": {"displayMode": "auto", "filterable": true}},
        "overrides": [
          {"matcher": {"id": "byName", "options": "cpu_cores"}, "properties": [{"id": "unit", "value": "short"}, {"id": "displayName", "value": "CPU (cores)"}, {"id": "custom.displayMode", "value": "color-background"}, {"id": "thresholds", "value": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.5}, {"color": "red", "value": 1.0}]}}]},
          {"matcher": {"id": "byName", "options": "memory_bytes"}, "properties": [{"id": "unit", "value": "bytes"}, {"id": "displayName", "value": "Memory"}]},
          {"matcher": {"id": "byName", "options": "rx_bps"}, "properties": [{"id": "unit", "value": "Bps"}, {"id": "displayName", "value": "Net RX"}]},
          {"matcher": {"id": "byName", "options": "tx_bps"}, "properties": [{"id": "unit", "value": "Bps"}, {"id": "displayName", "value": "Net TX"}]}
        ]
      },
      "options": {"sortBy": [{"displayName": "CPU (cores)", "desc": true}], "footer": {"show": false}},
      "transformations": [{"id": "merge", "options": {}}],
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_cpu_usage_nanoseconds_total{container_name=~\"$container\"}[$__rate_interval]) / 1e9", "legendFormat": "", "instant": true, "format": "table"},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "container_memory_usage_total_bytes{container_name=~\"$container\"}", "legendFormat": "", "instant": true, "format": "table"},
        {"refId": "C", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_network_io_usage_rx_bytes_total{container_name=~\"$container\"}[$__rate_interval])", "legendFormat": "", "instant": true, "format": "table"},
        {"refId": "D", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "rate(container_network_io_usage_tx_bytes_total{container_name=~\"$container\"}[$__rate_interval])", "legendFormat": "", "instant": true, "format": "table"}
      ]
    },

    {
      "id": 60, "type": "row", "title": "OTel Collector Health", "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 66}
    },
    {
      "id": 61, "type": "stat", "title": "Spans Accepted/s",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 67},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "green"}},
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(otelcol_receiver_accepted_spans_total[$__rate_interval]))", "legendFormat": "spans/s"}]
    },
    {
      "id": 62, "type": "stat", "title": "Spans Dropped/s",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 67},
      "fieldConfig": {
        "defaults": {
          "unit": "short", "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}
        }, "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "background"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(otelcol_processor_dropped_spans_total[$__rate_interval]))", "legendFormat": "dropped/s"}]
    },
    {
      "id": 63, "type": "stat", "title": "Metrics Points/s",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 67},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "blue"}},
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(otelcol_receiver_accepted_metric_points_total[$__rate_interval]))", "legendFormat": "points/s"}]
    },
    {
      "id": 64, "type": "stat", "title": "Log Records/s",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 67},
      "fieldConfig": {
        "defaults": {"unit": "short", "color": {"mode": "fixed", "fixedColor": "orange"}},
        "overrides": []
      },
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "textMode": "auto", "colorMode": "value"},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(otelcol_receiver_accepted_log_records_total[$__rate_interval]))", "legendFormat": "logs/s"}]
    },
    {
      "id": 65, "type": "timeseries", "title": "OTel Collector Throughput",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 71},
      "fieldConfig": {"defaults": {"unit": "short", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 5}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(otelcol_receiver_accepted_spans_total[$__rate_interval]))", "legendFormat": "spans accepted/s"},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(otelcol_processor_dropped_spans_total[$__rate_interval]))", "legendFormat": "spans dropped/s"},
        {"refId": "C", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(otelcol_receiver_accepted_metric_points_total[$__rate_interval]))", "legendFormat": "metric points/s"},
        {"refId": "D", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "sum(rate(otelcol_receiver_accepted_log_records_total[$__rate_interval]))", "legendFormat": "log records/s"}
      ]
    },
    {
      "id": 66, "type": "timeseries", "title": "OTel Collector Memory Usage",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 79},
      "fieldConfig": {"defaults": {"unit": "bytes", "min": 0, "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [
        {"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "otelcol_process_memory_rss", "legendFormat": "RSS"},
        {"refId": "B", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "go_memstats_alloc_bytes{job=\"otelcol\"}", "legendFormat": "Heap alloc"}
      ]
    },
    {
      "id": 67, "type": "timeseries", "title": "OTel Exporter Queue Size",
      "description": "Queue fill ratio > 0.8 = queue full alert will fire.",
      "datasource": {"type": "prometheus", "uid": "mimir"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 79},
      "fieldConfig": {"defaults": {"unit": "percentunit", "min": 0, "max": 1, "custom": {"lineWidth": 2, "fillOpacity": 10}}, "overrides": []},
      "options": {"tooltip": {"mode": "multi"}, "legend": {"displayMode": "table", "placement": "bottom"}},
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "mimir"}, "expr": "otelcol_exporter_queue_size / otelcol_exporter_queue_capacity", "legendFormat": "{{exporter}}"}]
    }
  ]
}
